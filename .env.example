# Deployer private key (without 0x prefix)
PRIVATE_KEY=

# Treasury admin address
TREASURY_ADMIN=0x...

# Multi-sig configuration
SIGNER_THRESHOLD=2
MIN_DELAY=86400

# Comma-separated list of signer addresses
SIGNERS=0x...,0x...,0x...

# Optional: Etherscan API key for contract verification
ETHERSCAN_API_KEY=
